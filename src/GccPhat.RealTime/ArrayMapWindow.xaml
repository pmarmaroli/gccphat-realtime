<Window x:Class="GccPhat.RealTime.ArrayMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Array map" Height="560" Width="880"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14">
    <DockPanel>
        <TextBlock DockPanel.Dock="Bottom" x:Name="AzimuthLabel" Margin="12,6"
                   Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="16" Text="Azimuth: --" />
        <Grid Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="LOCALIZATION" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"
                               FontWeight="Bold" FontSize="20" />
                    <TextBlock Text="SRP-PHAT needs at least 2 channel pairs."
                               Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />

                    <TextBlock Style="{StaticResource SectionHeader}" Text="CHANNEL PAIRS" Margin="0,12,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="A" Foreground="{StaticResource TextDimBrush}" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelA}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                            <TextBlock Text="B" Foreground="{StaticResource TextDimBrush}" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelB}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Add" Width="72" VerticalAlignment="Bottom"
                                Command="{Binding AddPairCommand}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding ActivePairs}" SelectedItem="{Binding SelectedPair}"
                             BorderThickness="0" Background="Transparent" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,0,0,6" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="13" Height="13" Margin="0,0,8,0"
                                                 Fill="{Binding QualityBrush}" VerticalAlignment="Center" />
                                        <Rectangle Width="14" Height="14" Margin="0,0,8,0"
                                                   Fill="{Binding ColorBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Label}" Width="86" VerticalAlignment="Center"
                                                   FontSize="15" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding DelayText}" FontFamily="Consolas" FontSize="16"
                                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove selected pair" Margin="0,4,0,0" HorizontalAlignment="Left" Width="200"
                            Command="{Binding RemoveSelectedPairCommand}" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Canvas x:Name="MapCanvas" ClipToBounds="True" SizeChanged="OnCanvasSizeChanged" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
