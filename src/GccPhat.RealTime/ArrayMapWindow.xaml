<Window x:Class="GccPhat.RealTime.ArrayMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Array map" Height="560" Width="880"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14">
    <DockPanel>
        <DockPanel DockPanel.Dock="Bottom" Margin="12,4">
            <CheckBox DockPanel.Dock="Right" Content="Hemisphere view" VerticalAlignment="Center"
                      IsChecked="{Binding ShowHemisphere}"
                      Foreground="{StaticResource TextDimBrush}" />
            <TextBlock x:Name="AzimuthLabel"
                       Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="16" Text="Azimuth: --" />
        </DockPanel>
        <Grid Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="LOCALIZATION" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"
                               FontWeight="Bold" FontSize="20" />
                    <TextBlock Text="{Binding LocalizationPairSummaryText}"
                               Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LocalizationPairHintText}"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />

                    <Border Visibility="{Binding LocalizationPairsAutoApplied, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource FieldBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10" Margin="0,10,0,0">
                        <TextBlock Text="Default selection: opposite pairs (each mic paired with the one across the array). Change it anytime below."
                                   Foreground="{StaticResource AccentBrush}" FontSize="12" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="CHANNEL PAIRS" Margin="0,12,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="A" Foreground="{StaticResource TextDimBrush}" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelA}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                            <TextBlock Text="B" Foreground="{StaticResource TextDimBrush}" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelB}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Add" Width="72" VerticalAlignment="Bottom"
                                Command="{Binding AddPairCommand}" />
                    </Grid>

                    <TextBlock Text="Quick add:" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,10,0,4" />
                    <StackPanel>
                        <Button Content="Opposite pairs" Margin="0,0,0,6"
                                Command="{Binding AddOppositePairsCommand}"
                                ToolTip="Toggle: pairs each microphone with the one diametrically opposite it (circular layout, even mic count). Click again to remove them." />
                        <Button Content="Consecutive pairs" Margin="0,0,0,6"
                                Command="{Binding AddConsecutivePairsCommand}"
                                ToolTip="Toggle: pairs each microphone with its immediate neighbor around the array. Click again to remove them." />
                        <Button Content="All possible pairs"
                                Command="{Binding AddAllPairsCommand}"
                                ToolTip="Toggle: adds every pair among the currently assigned microphones. Click again to remove them." />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ActivePairs}" SelectedItem="{Binding SelectedPair}"
                             BorderThickness="0" Background="Transparent" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,0,0,6" Padding="10,6">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right" CornerRadius="4" Padding="7,2" Margin="10,0,0,0"
                                                    BorderBrush="{Binding LocalizationStatusBrush}" BorderThickness="1">
                                                <TextBlock Text="{Binding LocalizationBadgeText}" FontFamily="Consolas"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{Binding LocalizationStatusBrush}" />
                                            </Border>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="13" Height="13" Margin="0,0,8,0"
                                                         Fill="{Binding QualityBrush}" VerticalAlignment="Center" />
                                                <Rectangle Width="14" Height="14" Margin="0,0,8,0"
                                                           Fill="{Binding ColorBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Label}" Width="86" VerticalAlignment="Center"
                                                           FontSize="15" Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding DelayText}" FontFamily="Consolas" FontSize="16"
                                                           FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DockPanel>
                                        <TextBlock Text="{Binding LocalizationStatusText}" Margin="35,4,0,0" FontSize="12"
                                                   Foreground="{Binding LocalizationStatusBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove selected pair" Margin="0,4,0,0" HorizontalAlignment="Left" Width="200"
                            Command="{Binding RemoveSelectedPairCommand}" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Canvas x:Name="MapCanvas" ClipToBounds="True" SizeChanged="OnCanvasSizeChanged" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
