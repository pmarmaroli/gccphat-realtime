<Window x:Class="GccPhat.RealTime.BeamformerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beamformer" SizeToContent="Height" MinHeight="320" MaxHeight="900" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14">
    <DockPanel>
        <Border Margin="12" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="BEAMFORMER" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                           FontFamily="Consolas" FontSize="20" />
                <TextBlock Text="Steer a mono listening beam toward a chosen azimuth."
                           Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />

                <Border Margin="0,14,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <TextBlock Text="{Binding BeamWorkflowText}" Foreground="{StaticResource AccentBrush}"
                               FontSize="12" TextWrapping="Wrap" />
                </Border>

                <Border Margin="0,14,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Beamforming mode" Foreground="{StaticResource TextBrush}" />
                        <ComboBox Margin="0,8,0,0" ItemsSource="{Binding BeamformerModeOptions}" SelectedItem="{Binding SelectedBeamformerMode}" />
                        <TextBlock Text="{Binding BeamModeDescriptionText}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding BeamModeStatusText}" Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Steering azimuth (degrees)" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="0° = +X axis of the array geometry, counter-clockwise positive."
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,4,0,0" />
                        <Grid Height="220" Margin="0,12,0,0">
                            <Canvas x:Name="AzimuthPreviewCanvas" ClipToBounds="True" SizeChanged="OnAzimuthPreviewSizeChanged" />
                        </Grid>
                        <TextBlock Text="Top view of the array. Bright mics feed the beam; dim mics are excluded."
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                            <Slider Width="300" Minimum="0" Maximum="360" Value="{Binding BeamAzimuthDeg, Mode=TwoWay}" />
                            <TextBlock Text="{Binding BeamAzimuthDeg, StringFormat={}{0:F0}°}" Margin="12,0,0,0"
                                       VerticalAlignment="Center" FontFamily="Consolas" FontSize="16"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Microphones in beam" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Pick which mics contribute to the beam sum (changes apply live)."
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,4,0,6" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding MicPositions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IncludeInBeam}" VerticalAlignment="Center"
                                                  ToolTip="Include this microphone in the beamformer sum" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CoordText}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding Channel, StringFormat=ch {0}}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <CheckBox Content="Limit to array's useful band" IsChecked="{Binding BeamBandLimit}"
                                  Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="{Binding BeamBandText}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="Below c/(2·aperture) the array has no directivity; above c/(2·min-spacing) it aliases."
                                   Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Output gain boost" Foreground="{StaticResource TextBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                            <Slider Width="300" Minimum="0" Maximum="40" TickFrequency="6" IsSnapToTickEnabled="False"
                                    Value="{Binding BeamGainDb, Mode=TwoWay}" />
                            <TextBlock Text="{Binding BeamGainText}" Margin="12,0,0,0" VerticalAlignment="Center"
                                       FontFamily="Consolas" FontSize="16" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Render speaker / output" Foreground="{StaticResource TextBrush}" />
                        <ComboBox Margin="0,8,0,0" ItemsSource="{Binding RenderDevices}" SelectedItem="{Binding SelectedRenderDevice}" />
                        <TextBlock Text="{Binding BeamListenStateText}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <TextBlock Text="{Binding BeamProcessingText}" Foreground="{StaticResource TextDimBrush}"
                               FontSize="12" TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button Content="{Binding BeamListenButtonText}" Width="140" Command="{Binding ListenCommand}" />
                    <Button Content="Close" Width="90" Margin="12,0,0,0" Click="OnClose" />
                </StackPanel>

                <TextBlock Text="Prototype: frequency-domain delay-and-sum plus an auto-order differential variant."
                           Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
            </StackPanel>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>