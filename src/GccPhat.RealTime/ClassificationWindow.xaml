<Window x:Class="GccPhat.RealTime.ClassificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Classification" Height="560" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding ClassificationVm.UpdateTimeText}"
                           Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding ClassificationVm.ChannelText}"
                           Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="16"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border Margin="12" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
            <StackPanel>
                <TextBlock Text="CLASSIFICATION" Foreground="{StaticResource AccentBrush}"
                           FontFamily="Consolas" FontWeight="Bold" FontSize="20" />

                <!-- Channel selector -->
                <DockPanel Margin="0,10,0,0">
                    <TextBlock DockPanel.Dock="Left" Text="Input channel" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,10,0" />
                    <ComboBox ItemsSource="{Binding AvailableChannels}"
                              SelectedItem="{Binding ClassificationChannel}" Width="80" HorizontalAlignment="Left" />
                </DockPanel>

                <!-- Model status (shown when model is not available or there is an error) -->
                <TextBlock Text="{Binding ClassificationVm.StatusText}" TextWrapping="Wrap"
                           Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" FontSize="11"
                           Margin="0,10,0,0"
                           Visibility="{Binding ClassificationVm.HasStatus, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="TOP RESULTS" Style="{StaticResource SectionHeader}" Margin="0,14,0,8" />

                <!-- Results list -->
                <ItemsControl ItemsSource="{Binding ClassificationVm.TopResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextBrush}"
                                               FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <Border Height="6" CornerRadius="3" HorizontalAlignment="Left"
                                            Width="{Binding BarWidth}" Background="{StaticResource AccentBrush}"
                                            Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding ScoreText}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
