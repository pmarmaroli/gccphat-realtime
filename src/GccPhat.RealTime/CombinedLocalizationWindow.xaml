<Window x:Class="GccPhat.RealTime.CombinedLocalizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Combined localization" Height="560" Width="880"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14">
    <DockPanel>
        <DockPanel DockPanel.Dock="Bottom" Margin="12,4">
            <TextBlock Text="{Binding FixStatusText}"
                       Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="16" />
        </DockPanel>
        <Grid Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="COMBINED LOCALIZATION" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"
                               FontWeight="Bold" FontSize="20" />
                    <TextBlock Text="Combines the live azimuth from two open analysis windows into a 2D (x,y) source fix. Assumes both arrays share the same orientation (no relative rotation)."
                               Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />

                    <Border Visibility="{Binding NeedsMoreSessions, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource FieldBrush}" BorderBrush="{StaticResource WarnBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="This panel only combines windows that are already open and started — it doesn't open capture devices itself."
                                       Foreground="{StaticResource WarnBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <Button Content="New analysis window &#8599;" Height="34" Click="OnNewAnalysisWindow" />
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="ARRAYS" Margin="0,12,0,8" />
                    <TextBlock Text="Array A" Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                    <ComboBox ItemsSource="{Binding AvailableSessions}" DisplayMemberPath="SessionLabel"
                              SelectedItem="{Binding SessionA}" Margin="0,2,0,8" />
                    <TextBlock Text="Array B" Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                    <ComboBox ItemsSource="{Binding AvailableSessions}" DisplayMemberPath="SessionLabel"
                              SelectedItem="{Binding SessionB}" Margin="0,2,0,0" />

                    <TextBlock Style="{StaticResource SectionHeader}" Text="OFFSET (B relative to A)" Margin="0,12,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="&#916;x (cm)" Foreground="{StaticResource TextDimBrush}" FontSize="11" />
                            <TextBox Text="{Binding OffsetXCm, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                            <TextBlock Text="&#916;y (cm)" Foreground="{StaticResource TextDimBrush}" FontSize="11" />
                            <TextBox Text="{Binding OffsetYCm, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="&#916;z (cm)" Foreground="{StaticResource TextDimBrush}" FontSize="11" />
                            <TextBox Text="{Binding OffsetZCm, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="&#916;z is informational only — the 2D fix has no elevation data to combine it with."
                               Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />

                    <TextBlock Style="{StaticResource SectionHeader}" Text="LIVE BEARINGS" Margin="0,12,0,8" />
                    <TextBlock Text="{Binding SessionA.SessionLabel, StringFormat='A: {0}'}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding SessionA.AzimuthText}" FontFamily="Consolas" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding SessionB.SessionLabel, StringFormat='B: {0}'}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource WarnBrush}" />
                    <TextBlock Text="{Binding SessionB.AzimuthText}" FontFamily="Consolas" Foreground="{StaticResource TextBrush}" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Canvas x:Name="MapCanvas" ClipToBounds="True" SizeChanged="OnCanvasSizeChanged" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
