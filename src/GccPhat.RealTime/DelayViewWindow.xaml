<Window x:Class="GccPhat.RealTime.DelayViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Delay view" Height="760" Width="1180"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Margin="12,0,12,12" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,8">
            <DockPanel>
                <TextBlock x:Name="SummaryText" Text="Waiting for live delay data..."
                           Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Content="Close" Width="90" Margin="12,0,0,0" Click="OnClose" />
            </DockPanel>
        </Border>

        <Grid Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="DELAY VIEW" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"
                               FontWeight="Bold" FontSize="20" />

                    <!-- Channel pairs -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="CHANNEL PAIRS" Margin="0,12,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="A" Foreground="{StaticResource TextDimBrush}" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelA}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                            <TextBlock Text="B" Foreground="{StaticResource TextDimBrush}" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelB}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Add" Width="72" VerticalAlignment="Bottom"
                                Command="{Binding AddPairCommand}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding ActivePairs}" SelectedItem="{Binding SelectedPair}"
                             BorderThickness="0" Background="Transparent" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,0,0,8" Padding="10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="13" Height="13" Margin="0,0,8,0"
                                                     Fill="{Binding QualityBrush}" VerticalAlignment="Center" />
                                            <Rectangle Width="14" Height="14" Margin="0,0,8,0"
                                                       Fill="{Binding ColorBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Label}" Width="86" VerticalAlignment="Center"
                                                       FontSize="15" Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{Binding DelayText}" FontFamily="Consolas" FontSize="16"
                                                       FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="22,4,0,0">
                                            <TextBlock Text="{Binding VerdictText}" FontWeight="Bold" Foreground="{Binding VerdictBrush}" />
                                            <TextBlock Text="{Binding CorrText}" FontFamily="Consolas"
                                                       Foreground="{StaticResource TextDimBrush}" Margin="10,0,0,0" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                            <TextBlock Text="{Binding LevelAText}" FontFamily="Consolas"
                                                       Foreground="{StaticResource TextDimBrush}" />
                                            <TextBlock Text="{Binding LevelBText}" FontFamily="Consolas"
                                                       Foreground="{StaticResource TextDimBrush}" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove selected pair" Margin="0,4,0,0" HorizontalAlignment="Left" Width="200"
                            Command="{Binding RemoveSelectedPairCommand}" />

                    <!-- Plot axes -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="PLOT AXES" Margin="0,16,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="X axis (time)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="Auto (full)" IsChecked="{Binding XAutoScale}" Margin="0,0,0,6" />
                            <Grid IsEnabled="{Binding CanEditXRange}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="window (s)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Margin="8,0,0,0" Text="{Binding XWindowSeconds}" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Y axis (delay, ms)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="Auto-scale" IsChecked="{Binding YAutoScale}" Margin="0,0,0,6" />
                            <Grid IsEnabled="{Binding CanEditYRange}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="min" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Margin="5,0" Text="{Binding YMin}" />
                                <TextBlock Grid.Column="2" Text="max" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="3" Margin="5,0,0,0" Text="{Binding YMax}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                <sp:WpfPlot x:Name="DelayPlot" />
            </Border>
        </Grid>
    </DockPanel>
</Window>