<Window x:Class="GccPhat.RealTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GccPhat.RealTime"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="GCC-PHAT // Real-Time Microphone Array" Height="900" Width="1480"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14" TextOptions.TextFormattingMode="Display">
    <DockPanel>

        <!-- ===================== Status bar ===================== -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" />
            </StackPanel>
        </Border>

        <!-- ===================== Left control panel ===================== -->
        <Border DockPanel.Dock="Left" Width="450" Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,10,12">
                <StackPanel>

                    <TextBlock Margin="2,0,0,14">
                        <Run Text="&#9670; GCC-PHAT" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="22" />
                        <Run Text="// REALTIME" Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" FontSize="22" />
                    </TextBlock>

                    <!-- Device -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="CAPTURE DEVICE" />
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Refresh" Width="74" Margin="8,0,0,0"
                                        Command="{Binding RefreshDevicesCommand}" IsEnabled="{Binding CanEditConfig}" />
                                <ComboBox ItemsSource="{Binding Devices}"
                                          SelectedItem="{Binding SelectedDevice}"
                                          IsEnabled="{Binding CanEditConfig}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Identify -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <ToggleButton x:Name="IdentifyToggle" Style="{StaticResource ExpanderHeader}"
                                          Content="IDENTIFY &#183; BLOW ON A MIC" IsChecked="True" Margin="0,0,0,8" />
                            <StackPanel Visibility="{Binding IsChecked, ElementName=IdentifyToggle, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding DetectedChannelText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="15" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ChannelMeters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="82" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontFamily="Consolas" FontSize="15"
                                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                            <ProgressBar Grid.Column="1" Height="20" Minimum="0" Maximum="100"
                                                         Value="{Binding BarValue, Mode=OneWay}" Foreground="{Binding BarBrush}" />
                                            <TextBlock Grid.Column="2" Text="{Binding LevelText}" FontFamily="Consolas" FontSize="14"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Channel pairs -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="CHANNEL PAIRS" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="A" Foreground="{StaticResource TextDimBrush}" />
                                    <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelA}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                    <TextBlock Text="B" Foreground="{StaticResource TextDimBrush}" />
                                    <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding SelectedChannelB}" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="Add" Width="72" VerticalAlignment="Bottom"
                                        Command="{Binding AddPairCommand}" />
                            </Grid>

                            <ListBox ItemsSource="{Binding ActivePairs}" SelectedItem="{Binding SelectedPair}"
                                     Height="130" Margin="0,10,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="13" Height="13" Margin="0,0,8,0"
                                                         Fill="{Binding QualityBrush}" VerticalAlignment="Center" />
                                                <Rectangle Width="14" Height="14" Margin="0,0,8,0"
                                                           Fill="{Binding ColorBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Label}" Width="86" VerticalAlignment="Center"
                                                           FontSize="15" Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding DelayText}" FontFamily="Consolas" FontSize="17" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="34,2,0,0">
                                                <TextBlock Text="{Binding VerdictText}" FontSize="14" FontWeight="Bold" Foreground="{Binding VerdictBrush}" />
                                                <TextBlock Text="{Binding CorrText}" FontFamily="Consolas" FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="12,0,0,0" />
                                                <TextBlock Text="{Binding DiffText}" FontFamily="Consolas" FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="12,0,0,0" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="34,2,0,0">
                                                <TextBlock Text="{Binding LevelAText}" FontFamily="Consolas" FontSize="14" Foreground="{StaticResource TextDimBrush}" />
                                                <TextBlock Text="{Binding LevelBText}" FontFamily="Consolas" FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="12,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding SignalText}" Foreground="{StaticResource DangerBrush}" FontSize="13" Margin="34,0,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Content="Remove selected pair" Margin="0,8,0,0" HorizontalAlignment="Left" Width="200"
                                    Command="{Binding RemoveSelectedPairCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Analysis parameters -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="ANALYSIS" />
                            <Grid IsEnabled="{Binding CanEditConfig}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Window (samples)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,4" ItemsSource="{Binding BufferSizeOptions}" SelectedItem="{Binding SelectedBufferSize}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="fmin (Hz)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="8,4" Text="{Binding Fmin}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="fmax (Hz)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,4" Text="{Binding Fmax}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Refresh (ms)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="8,4" Text="{Binding UpdateIntervalMs}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                       Text="Sliding window: each estimate is computed on the latest Window samples (this sets the max measurable delay &amp; the frequency resolution). Refresh sets how often the plot updates &#8212; with Refresh below Window/fs the analysis windows overlap." />
                        </StackPanel>
                    </Border>

                    <!-- Plot axes -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="PLOT AXES" />

                            <TextBlock Text="X axis (time)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="Auto (full history)" IsChecked="{Binding XAutoScale}" Margin="0,0,0,4" />
                            <Grid IsEnabled="{Binding CanEditXRange}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="window (s)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Margin="8,0" Text="{Binding XWindowSeconds}" />
                            </Grid>

                            <TextBlock Text="Y axis (delay, ms)" Foreground="{StaticResource TextBrush}" Margin="0,12,0,4" />
                            <CheckBox Content="Auto-scale" IsChecked="{Binding YAutoScale}" Margin="0,0,0,4" />
                            <Grid IsEnabled="{Binding CanEditYRange}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="min" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Margin="6,0" Text="{Binding YMin}" />
                                <TextBlock Grid.Column="2" Text="max" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBox Grid.Column="3" Margin="6,0" Text="{Binding YMax}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Transport -->
                    <Grid Margin="0,2,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="START" Height="48" FontSize="16" Margin="0,0,5,0"
                                Style="{StaticResource AccentButton}" Command="{Binding StartCommand}" />
                        <Button Grid.Column="1" Content="STOP" Height="48" FontSize="16" Margin="5,0,0,0"
                                Command="{Binding StopCommand}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===================== Plot ===================== -->
        <Border Margin="12" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6">
            <sp:WpfPlot x:Name="DelayPlot" />
        </Border>
    </DockPanel>
</Window>
