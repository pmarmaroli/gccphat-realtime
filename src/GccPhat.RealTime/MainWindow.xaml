<Window x:Class="GccPhat.RealTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GccPhat.RealTime"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="GCC-PHAT Real-Time — Microphone Array Delay Viewer" Height="680" Width="1180">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left" Width="360" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">

                    <TextBlock Text="Capture device" FontWeight="Bold" Margin="0,0,0,4" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Refresh" Width="70" Margin="6,0,0,0"
                                Command="{Binding RefreshDevicesCommand}" IsEnabled="{Binding CanEditConfig}" />
                        <ComboBox ItemsSource="{Binding Devices}"
                                  SelectedItem="{Binding SelectedDevice}"
                                  IsEnabled="{Binding CanEditConfig}" />
                    </DockPanel>

                    <TextBlock Text="Identify channels (blow on a mic)" FontWeight="Bold" Margin="0,12,0,2" />
                    <TextBlock Text="{Binding DetectedChannelText}" TextWrapping="Wrap"
                               Foreground="#2C3E50" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding ChannelMeters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="14" Minimum="0" Maximum="100"
                                                 Value="{Binding BarValue, Mode=OneWay}" Foreground="{Binding BarBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding LevelText}" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,12" />

                    <TextBlock Text="Channel pair" FontWeight="Bold" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="A" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}"
                                      SelectedItem="{Binding SelectedChannelA}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                            <TextBlock Text="B" />
                            <ComboBox ItemsSource="{Binding AvailableChannels}"
                                      SelectedItem="{Binding SelectedChannelB}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Add" Width="60" VerticalAlignment="Bottom"
                                Command="{Binding AddPairCommand}" />
                    </Grid>

                    <TextBlock Text="Active pairs" FontWeight="Bold" Margin="0,12,0,4" />
                    <ListBox ItemsSource="{Binding ActivePairs}"
                             SelectedItem="{Binding SelectedPair}"
                             Height="230">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,3">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                                                 Fill="{Binding QualityBrush}" VerticalAlignment="Center" />
                                        <Rectangle Width="12" Height="12" Margin="0,0,6,0"
                                                   Fill="{Binding ColorBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Label}" Width="76" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DelayText}" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="28,1,0,0">
                                        <TextBlock Text="{Binding VerdictText}" FontWeight="Bold"
                                                   Foreground="{Binding VerdictBrush}" />
                                        <TextBlock Text="{Binding CorrText}" FontFamily="Consolas" Foreground="#555" Margin="10,0,0,0" />
                                        <TextBlock Text="{Binding DiffText}" FontFamily="Consolas" Foreground="#555" Margin="10,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="28,1,0,0">
                                        <TextBlock Text="{Binding LevelAText}" FontFamily="Consolas" Foreground="#888" />
                                        <TextBlock Text="{Binding LevelBText}" FontFamily="Consolas" Foreground="#888" Margin="10,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SignalText}" Foreground="#C0392B" FontSize="11" Margin="28,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove selected pair" Margin="0,4,0,0" HorizontalAlignment="Left" Width="160"
                            Command="{Binding RemoveSelectedPairCommand}" />

                    <Separator Margin="0,12" />

                    <TextBlock Text="Parameters" FontWeight="Bold" Margin="0,0,0,4" />
                    <Grid IsEnabled="{Binding CanEditConfig}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Window (samples)" VerticalAlignment="Center" Margin="0,4" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="6,4"
                                  ItemsSource="{Binding BufferSizeOptions}"
                                  SelectedItem="{Binding SelectedBufferSize}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="fmin (Hz)" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="6,4" Text="{Binding Fmin}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="fmax (Hz)" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="6,4" Text="{Binding Fmax}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Update (ms)" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="6,4" Text="{Binding UpdateIntervalMs}" />
                    </Grid>

                    <TextBlock Text="Delay plot Y axis (ms)" FontWeight="Bold" Margin="0,12,0,4" />
                    <CheckBox Content="Auto-scale" IsChecked="{Binding YAutoScale}" Margin="0,0,0,4" />
                    <Grid IsEnabled="{Binding CanEditYRange}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="min" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Margin="6,0" Text="{Binding YMin}" />
                        <TextBlock Grid.Column="2" Text="max" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBox Grid.Column="3" Margin="6,0" Text="{Binding YMax}" />
                    </Grid>

                    <Separator Margin="0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Start" Height="34" Margin="0,0,4,0"
                                Command="{Binding StartCommand}" />
                        <Button Grid.Column="1" Content="Stop" Height="34" Margin="4,0,0,0"
                                Command="{Binding StopCommand}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <sp:WpfPlot x:Name="DelayPlot" />
    </DockPanel>
</Window>
