<Window x:Class="GccPhat.RealTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GccPhat.RealTime"
        mc:Ignorable="d"
        Title="GCC-PHAT // Real-Time Microphone Array" Height="900" Width="1480"
        Background="{StaticResource BgBrush}" FontFamily="Segoe UI" FontSize="14" TextOptions.TextFormattingMode="Display">
    <DockPanel>

        <!-- ===================== Status bar ===================== -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" />
            </StackPanel>
        </Border>

        <!-- ===================== Left control panel ===================== -->
        <Border DockPanel.Dock="Left" Width="450" Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,10,12">
                <StackPanel>

                    <DockPanel Margin="2,0,0,14">
                        <Grid DockPanel.Dock="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="New analysis window &#8599;" Height="40" FontSize="12" Margin="0,0,16,0"
                                    Click="OnNewWindow"
                                    ToolTip="Open a second, independent capture/analysis chain for a second microphone array." />
                            <Button Grid.Column="1" Content="START" Height="40" MinWidth="96" FontSize="15" Margin="0,0,8,0"
                                    Style="{StaticResource AccentButton}" Command="{Binding StartCommand}" />
                            <Button Grid.Column="2" Content="STOP" Height="40" MinWidth="96" FontSize="15"
                                    Command="{Binding StopCommand}" />
                        </Grid>
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="&#9670; GCC-PHAT" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="22" />
                            <Run Text="// REALTIME" Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" FontSize="22" />
                        </TextBlock>
                    </DockPanel>

                    <!-- Activity gate: always visible, drives whether anything downstream runs -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="ACTIVITY GATE" />
                            <TextBlock Text="Delay, localization, beamforming, and classification all pause while the array is quieter than this."
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider Width="220" Minimum="-96" Maximum="0" TickFrequency="8" IsSnapToTickEnabled="False"
                                        Value="{Binding LevelThresholdDb, Mode=TwoWay}" />
                                <TextBlock Text="{Binding LevelThresholdDb, StringFormat={}{0:F0} dB}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="16"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding LevelText}" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding GateStatusText}" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Device -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="CAPTURE DEVICE" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" IsEnabled="{Binding CanEditConfig}">
                                <RadioButton Content="Live device" GroupName="CaptureMode" IsChecked="{Binding IsLiveMode}" Margin="0,0,16,0" />
                                <RadioButton Content="Audio file" GroupName="CaptureMode" IsChecked="{Binding IsFileMode}" />
                            </StackPanel>

                            <DockPanel Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVis}}">
                                <Button DockPanel.Dock="Right" Content="Refresh" Width="74" Margin="8,0,0,0"
                                        Command="{Binding RefreshDevicesCommand}" IsEnabled="{Binding CanEditConfig}" />
                                <ComboBox ItemsSource="{Binding Devices}"
                                          SelectedItem="{Binding SelectedDevice}"
                                          IsEnabled="{Binding CanEditConfig}" />
                            </DockPanel>

                            <StackPanel Visibility="{Binding IsFileMode, Converter={StaticResource BoolToVis}}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Browse&#8230;" Width="74" Margin="8,0,0,0"
                                            Click="OnBrowseReplayFile" IsEnabled="{Binding CanEditConfig}" />
                                    <TextBlock Text="{Binding ReplayFileLabel}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <TextBlock Text="{Binding ReplayChannelsDetectedText}" Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Identify -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <ToggleButton x:Name="IdentifyToggle" Style="{StaticResource ExpanderHeader}"
                                          Content="IDENTIFY &#183; BLOW ON A MIC" IsChecked="False" Margin="0,0,0,8" />
                            <StackPanel Visibility="{Binding IsChecked, ElementName=IdentifyToggle, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding DetectedChannelText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="15" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ChannelMeters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="82" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontFamily="Consolas" FontSize="15"
                                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                            <ProgressBar Grid.Column="1" Height="20" Minimum="0" Maximum="100"
                                                         Value="{Binding BarValue, Mode=OneWay}" Foreground="{Binding BarBrush}" />
                                            <TextBlock Grid.Column="2" Text="{Binding LevelText}" FontFamily="Consolas" FontSize="14"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Geometry -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <ToggleButton x:Name="LocalizationToggle" Style="{StaticResource ExpanderHeader}"
                                          Content="GEOMETRY" IsChecked="False" Margin="0,0,0,8" />
                            <StackPanel Visibility="{Binding IsChecked, ElementName=LocalizationToggle, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Microphone layout and channel mapping used by both localization and beamforming."
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <Grid IsEnabled="{Binding CanEditConfig}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Array" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,4" ItemsSource="{Binding LayoutOptions}" SelectedItem="{Binding SelectedLayout}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mic count" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="8,4" Text="{Binding MicCount}" IsEnabled="{Binding CanEditMicCount}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Diameter (cm)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4"
                                           Visibility="{Binding IsCircular, Converter={StaticResource BoolToVis}}" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,4" Text="{Binding DiameterCm}"
                                         Visibility="{Binding IsCircular, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Spacing (cm)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4"
                                           Visibility="{Binding IsLinear, Converter={StaticResource BoolToVis}}" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,4" Text="{Binding SpacingCm}"
                                         Visibility="{Binding IsLinear, Converter={StaticResource BoolToVis}}" />
                                <CheckBox Grid.Row="3" Grid.Column="1" Margin="8,6,4,2" Content="Additional mic in the center"
                                         IsChecked="{Binding HasCenterMic}"
                                         Visibility="{Binding IsCircular, Converter={StaticResource BoolToVis}}" />
                                <ComboBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,4,2"
                                          ItemsSource="{Binding QuickPresetOptions}" SelectedItem="{Binding SelectedQuickPreset}" />
                            </Grid>

                            <!-- Saved geometry presets -->
                            <StackPanel Margin="0,10,4,2" IsEnabled="{Binding CanEditConfig}">
                                <TextBlock Text="Saved presets" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,0,0,4" />
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="Load" Width="60" Margin="6,0,0,0" Command="{Binding LoadPresetCommand}" />
                                    <ComboBox ItemsSource="{Binding PresetNames}" SelectedItem="{Binding SelectedPresetName}" />
                                </DockPanel>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Delete" Width="60" Margin="6,0,0,0" Command="{Binding DeletePresetCommand}" />
                                    <Button DockPanel.Dock="Right" Content="Save As" Width="66" Margin="6,0,0,0" Command="{Binding SaveAsPresetCommand}" />
                                    <Button DockPanel.Dock="Right" Content="Save" Width="52" Margin="6,0,0,0" Command="{Binding SavePresetCommand}" />
                                    <TextBox Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>

                            <!-- Custom layout: array-wide coordinate entry mode -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,4,2"
                                        Visibility="{Binding IsCustom, Converter={StaticResource BoolToVis}}"
                                        IsEnabled="{Binding CanEditConfig}">
                                <RadioButton Content="Cartesian (X/Y/Z)" GroupName="CustomInputMode" IsChecked="{Binding IsCustomCartesian}" Margin="0,0,16,0" />
                                <RadioButton Content="Spherical (Az/El/R)" GroupName="CustomInputMode" IsChecked="{Binding IsCustomSpherical}" />
                            </StackPanel>

                            <TextBlock Text="Assign channel to each position" Foreground="{StaticResource TextDimBrush}" Margin="0,8,0,2" FontSize="12" />

                            <!-- Circular/Linear: computed, read-only positions -->
                            <ItemsControl ItemsSource="{Binding MicPositions}" IsEnabled="{Binding CanEditConfig}"
                                          Visibility="{Binding IsNotCustom, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="92" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontFamily="Consolas" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding CoordText}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding Channel}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Custom: freely editable positions, cartesian or spherical entry -->
                            <ItemsControl ItemsSource="{Binding MicPositions}" IsEnabled="{Binding CanEditConfig}"
                                          Visibility="{Binding IsCustom, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        Visibility="{Binding DataContext.IsCustomCartesian, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}">
                                                <TextBox Width="50" Margin="1,0" Text="{Binding XMm}" ToolTip="X (mm)" />
                                                <TextBox Width="50" Margin="1,0" Text="{Binding YMm}" ToolTip="Y (mm)" />
                                                <TextBox Width="50" Margin="1,0" Text="{Binding ZMm}" ToolTip="Z (mm)" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        Visibility="{Binding DataContext.IsCustomSpherical, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}">
                                                <TextBox Width="50" Margin="1,0" Text="{Binding AzimuthDeg}" ToolTip="Azimuth (deg)" />
                                                <TextBox Width="50" Margin="1,0" Text="{Binding ElevationDeg}" ToolTip="Elevation (deg)" />
                                                <TextBox Width="50" Margin="1,0" Text="{Binding RadiusMm}" ToolTip="Radius (mm)" />
                                            </StackPanel>

                                            <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding Channel}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Analysis parameters -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <ToggleButton x:Name="AnalysisToggle" Style="{StaticResource ExpanderHeader}"
                                          Content="ANALYSIS" IsChecked="False" Margin="0,0,0,8" />
                            <StackPanel Visibility="{Binding IsChecked, ElementName=AnalysisToggle, Converter={StaticResource BoolToVis}}">
                            <Grid IsEnabled="{Binding CanEditConfig}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Window (samples)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,4" ItemsSource="{Binding BufferSizeOptions}" SelectedItem="{Binding SelectedBufferSize}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WindowDurationText}" Margin="8,0,0,6" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="fmin (Hz)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,4" Text="{Binding Fmin}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="fmax (Hz)" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="8,4" Text="{Binding Fmax}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                       Text="Each estimate is computed on one Window's worth of samples (this sets the max measurable delay &amp; the frequency resolution). Updates fire once per Window — no overlap, no gaps." />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===================== Tool launcher ===================== -->
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="18">
                <StackPanel>
                    <TextBlock Margin="0,0,0,8">
                        <Run Text="TOOLS" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="22" />
                        <Run Text=" // choose a workspace" Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas" FontSize="22" />
                    </TextBlock>
                    <TextBlock Text="Configuration stays here. Visualization and listening open in their own focused windows."
                               Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="2" Columns="3" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="DELAY VIEW" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Live delay traces and per-pair readouts in a dedicated window."
                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding DelayToolRequirementsText}"
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DelayToolStatusText}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,6,0,12" TextWrapping="Wrap" />
                        <Button Content="Open delay view &#8599;" Height="42" Click="OnShowDelayView" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="LOCALIZATION" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Compass-style array map driven by SRP-PHAT source azimuth."
                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding LocalizationToolRequirementsText}"
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LocalizationToolStatusText}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,6,0,12" TextWrapping="Wrap" />
                        <Button Content="Open array map &#8599;" Height="42" Click="OnShowArrayMap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="CLASSIFICATION" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="YAMNet sound-event classifier on one audio channel."
                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="Needs: device started, yamnet.onnx in Assets/."
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ClassificationVm.StatusText}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,6,0,12"
                                   TextWrapping="Wrap" MaxHeight="60" />
                        <Button Content="Open classification &#8599;" Height="42" Click="OnShowClassification" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="BEAMFORMER" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Steer a listening beam to a chosen azimuth and monitor the listening state."
                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding BeamformerToolRequirementsText}"
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding BeamformerToolStatusText}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,6,0,12" TextWrapping="Wrap" />
                        <Button Content="Open beamformer &#8599;" Height="42" Click="OnShowBeamformer" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="5,10,5,0">
                    <StackPanel>
                        <TextBlock Text="COMBINED LOCALIZATION" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Combines two open analysis windows' azimuths into a 2D (x,y) source fix, given the offset between the two arrays."
                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="Needs: two analysis windows open, each started with a live azimuth."
                                   Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" />
                        <Button Content="Open combined localization &#8599;" Height="42" Click="OnShowCombinedLocalization" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </DockPanel>
</Window>
